---
import { Play } from 'lucide-react';
import { formatPlayerTime } from '../../utils/player';

interface ActionItem { id: string; title: string; number: number; start: number; end: number; }
interface GroupItem { id: string; title: string; number: number; start: number; end: number; actions: ActionItem[]; }
interface Props { groups: GroupItem[]; }
const { groups } = Astro.props;
---

<div class="action-groups">
  {groups.map((group) => (
    <section class="action-group" aria-labelledby={`${group.id}-title`}>
      <header>
        <div><p>第 {group.number} 组</p><h2 id={`${group.id}-title`}>{group.title}</h2></div>
        <a href={`?t=${group.start}#${group.id}`}><Play size={17} aria-hidden="true" />{formatPlayerTime(group.start)}–{formatPlayerTime(group.end)}</a>
      </header>
      <ol id={group.id}>
        {group.actions.map((action) => (
          <li>
            <span class="action-group__number">{String(action.number).padStart(2, '0')}</span>
            <a href={`/routine/actions/${action.id}/`}>{action.title}</a>
            <a class="action-group__time" href={`/routine/actions/${action.id}/?t=${action.start}`}>{formatPlayerTime(action.start)}</a>
          </li>
        ))}
      </ol>
    </section>
  ))}
</div>

<style>
  .action-groups { display: grid; gap: var(--space-8); }
  .action-group { scroll-margin-top: calc(var(--header-height) + var(--space-4)); }
  .action-group header { display: flex; justify-content: space-between; gap: var(--space-4); align-items: end; padding-bottom: var(--space-3); border-bottom: 2px solid var(--color-ink); }
  .action-group header p { color: var(--color-vermilion-dark); font-size: 0.8125rem; font-weight: 800; }
  .action-group header h2 { font-size: 1.375rem; }
  .action-group header > a { display: inline-flex; min-height: 44px; align-items: center; gap: var(--space-2); font-size: 0.875rem; font-weight: 700; }
  .action-group ol { margin: 0; padding: 0; list-style: none; }
  .action-group li { display: grid; grid-template-columns: 3rem minmax(0, 1fr) 4.5rem; gap: var(--space-3); align-items: center; min-height: 3.5rem; border-bottom: 1px solid var(--color-line); }
  .action-group__number, .action-group__time { font-family: ui-monospace, SFMono-Regular, Consolas, monospace; font-size: 0.8125rem; font-variant-numeric: tabular-nums; }
  .action-group__number { color: var(--color-ink-soft); }
  .action-group li > a:not(.action-group__time) { display: flex; min-height: 44px; align-items: center; color: var(--color-ink); font-weight: 700; }
  .action-group__time { text-align: right; }
  @media (max-width: 35rem) {
    .action-group header { align-items: start; flex-direction: column; }
    .action-group li { grid-template-columns: 2.5rem minmax(0, 1fr) auto; padding-block: var(--space-2); }
  }
</style>
