---
interface TabItem { label: string; href: string; active?: boolean; }
interface Props { items: TabItem[]; label?: string; }
const { items, label = '内容视图' } = Astro.props;
---

<nav class="view-tabs" aria-label={label}>
  {items.map((item) => <a href={item.href} aria-current={item.active ? 'page' : undefined}>{item.label}</a>)}
</nav>

<style>
  .view-tabs { display: inline-flex; max-width: 100%; overflow-x: auto; border: 1px solid var(--color-line-strong); border-radius: var(--radius-control); background: var(--color-surface); }
  .view-tabs a { display: inline-flex; min-height: 44px; flex: 0 0 auto; align-items: center; padding: var(--space-2) var(--space-4); color: var(--color-ink); font-weight: 700; text-decoration: none; }
  .view-tabs a + a { border-left: 1px solid var(--color-line); }
  .view-tabs a[aria-current='page'], .view-tabs a:hover { background: var(--color-ink); color: white; }
</style>
