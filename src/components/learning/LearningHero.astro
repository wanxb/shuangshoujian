---
import { BookOpen, Play } from 'lucide-react';
---

<section class="learning-hero" aria-labelledby="learning-hero-title">
  <img
    src="/media/posters/home.webp"
    width="1920"
    height="700"
    alt="于承惠演示洗剑动作"
    fetchpriority="high"
  />
  <div class="learning-hero__overlay" aria-hidden="true"></div>
  <div class="container learning-hero__content">
    <p class="learning-hero__eyebrow">公开科普</p>
    <h1 id="learning-hero-title">于承惠双手剑</h1>
    <p>从双手剑二十法认识基本技法，结合教学影像理解击、刺、格、洗，再循序进入四十式完整套路。</p>
    <div class="learning-hero__actions">
      <a class="action-link" href="/learn/"><BookOpen size={19} aria-hidden="true" />从基础开始</a>
      <a class="action-link learning-hero__secondary" href="/practice/full-routine/"><Play size={19} aria-hidden="true" />观看整套</a>
    </div>
  </div>
</section>

<style>
  .learning-hero {
    position: relative;
    display: grid;
    min-height: min(38rem, 64dvh);
    align-items: end;
    overflow: hidden;
    background: var(--color-ink);
    color: white;
  }

  .learning-hero > img,
  .learning-hero__overlay {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .learning-hero > img {
    object-fit: cover;
    object-position: center;
  }

  .learning-hero__overlay {
    background: rgb(8 13 12 / 44%);
  }

  .learning-hero__content {
    position: relative;
    z-index: 1;
    display: grid;
    max-width: 48rem;
    gap: var(--space-4);
    margin-inline: auto;
    padding-block: var(--space-12);
  }

  .learning-hero__content h1,
  .learning-hero__content p {
    color: white;
  }

  .learning-hero__content h1 {
    max-width: 12ch;
  }

  .learning-hero__content > p:not(.learning-hero__eyebrow, .learning-hero__source) {
    max-width: 39rem;
    font-size: 1.125rem;
    line-height: 1.7;
  }

  .learning-hero__eyebrow {
    font-size: 0.8125rem;
    font-weight: 700;
  }

  .learning-hero__eyebrow {
    color: #f2c8bf !important;
  }

  .learning-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .learning-hero__secondary {
    border-color: rgb(255 255 255 / 70%);
    background: rgb(10 14 13 / 55%);
  }

  .learning-hero__secondary:hover {
    background: white;
    color: var(--color-ink);
  }

  @media (max-width: 40rem) {
    .learning-hero {
      min-height: min(34rem, 66dvh);
    }

    .learning-hero > img {
      object-position: right center;
    }

    .learning-hero__overlay {
      background: rgb(8 13 12 / 58%);
    }

    .learning-hero__content {
      padding-block: var(--space-8);
    }
  }
</style>
