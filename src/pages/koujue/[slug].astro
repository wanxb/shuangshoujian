---
import { getCollection } from 'astro:content';
import LessonPlayer from '../../components/learning/LessonPlayer';
import Breadcrumbs from '../../components/navigation/Breadcrumbs.astro';
import { MAIN_VIDEO } from '../../data/video-manifest';
import { SITE } from '../../data/site';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatPlayerTime } from '../../utils/player';
import { articleJsonLd, breadcrumbJsonLd, videoObjectJsonLd } from '../../utils/structured-data';

export async function getStaticPaths() {
  const verses = await getCollection('verses');
  return verses.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const playerSegments = entry.data.lines.map((line) => ({ id: line.id, title: line.transcription, start: line.start, end: line.end }));
const path = `/koujue/${entry.id}/`;
const site = Astro.site ?? new URL(SITE.url);
const description = `${entry.data.title}全文，共${entry.data.lines.length}句，含逐句视频时间码。`;
---

<BaseLayout title={entry.data.title} {description} canonicalPath={path} imagePath={`/media/posters/${entry.id}.webp`} type="article" structuredData={[
  breadcrumbJsonLd(site, [{ name: '首页', path: '/' }, { name: '双手剑歌诀', path: '/koujue/' }, { name: entry.data.title, path }]),
  articleJsonLd(site, { headline: entry.data.title, description, path, author: SITE.editorLabel, dateModified: entry.data.updatedAt }),
  videoObjectJsonLd(site, { name: entry.data.title, description, pagePath: path, contentPath: MAIN_VIDEO.publicSources.standard, thumbnailPath: `/media/posters/${entry.id}.webp`, duration: MAIN_VIDEO.duration, clips: entry.data.lines.map((line) => ({ name: line.transcription, start: line.start, end: line.end, path })) }),
]}>
  <div class="container"><Breadcrumbs items={[{ label: '双手剑歌诀', href: '/koujue/' }, { label: entry.data.title }]} /></div>
  <header class="section verse-detail-header"><div class="container verse-detail-header__grid"><div class="stack"><p class="eyebrow">视频片尾 · {formatPlayerTime(entry.data.start)} 起</p><h1>{entry.data.title}</h1><p class="lede">共 {entry.data.lines.length} 句，可按句定位视频。</p></div><p>{entry.data.attribution}</p></div></header>
  <section class="section verse-player-section" aria-label={`${entry.data.title}视频与逐句文字`}><div class="container"><LessonPlayer client:load title={entry.data.title} sources={{ standard: MAIN_VIDEO.publicSources.standard, lowBandwidth: MAIN_VIDEO.publicSources.lowBandwidth }} poster={`/media/posters/${entry.id}.webp`} segments={playerSegments} initialSegmentId={playerSegments[0]?.id} frameRate={MAIN_VIDEO.frameRate} showSegmentList segmentListLabel={`${entry.data.title}逐句列表`} /></div></section>
  <section id="transcription" class="section transcription-section" aria-labelledby="transcription-title"><div class="container verse-reading"><div class="verse-reading__heading"><p class="eyebrow">逐句正文</p><h2 id="transcription-title">歌诀全文</h2><p>点击时间可从对应字幕位置播放。</p></div><ol>{entry.data.lines.map((line) => <li id={line.id}><a href={`?t=${line.start}#${line.id}`}>{formatPlayerTime(line.start)}</a><p>{line.transcription}</p></li>)}</ol></div></section>
</BaseLayout>

<style>
  .verse-detail-header { padding-top: var(--space-8); }
  .verse-detail-header__grid { display: grid; grid-template-columns: minmax(0, 2fr) minmax(15rem, 1fr); gap: var(--space-10); align-items: end; }
  .verse-detail-header__grid > p { padding-top: var(--space-4); border-top: 1px solid var(--color-line-strong); color: var(--color-ink-soft); }
  .verse-player-section { padding-top: var(--space-6); }
  .transcription-section { background: var(--color-surface-muted); scroll-margin-top: var(--header-height); }
  .verse-reading { display: grid; grid-template-columns: minmax(15rem, 1fr) minmax(0, 2fr); gap: var(--space-10); align-items: start; }
  .verse-reading__heading { position: sticky; top: calc(var(--header-height) + var(--space-4)); }
  .verse-reading__heading > p:last-child { margin-top: var(--space-3); color: var(--color-ink-soft); }
  .verse-reading ol { margin: 0; padding: 0; border-top: 2px solid var(--color-ink); list-style: none; }
  .verse-reading li { display: grid; grid-template-columns: 4.5rem minmax(0, 1fr); gap: var(--space-3); align-items: center; min-height: 3.5rem; border-bottom: 1px solid var(--color-line); scroll-margin-top: calc(var(--header-height) + var(--space-4)); }
  .verse-reading li > a { font-family: ui-monospace, SFMono-Regular, Consolas, monospace; font-size: 0.8125rem; }
  .verse-reading li > p { font-family: 'Noto Serif SC', 'Songti SC', SimSun, serif; font-size: 1.0625rem; }
  @media (max-width: 47.9375rem) { .verse-detail-header__grid, .verse-reading { grid-template-columns: 1fr; } .verse-reading__heading { position: static; } }
  @media (max-width: 35rem) { .verse-reading li { grid-template-columns: 4rem minmax(0, 1fr); padding-block: var(--space-2); } }
</style>
